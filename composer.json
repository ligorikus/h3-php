{
    "name": "ligorikus/h3-php",
    "description": "Pure PHP implementation of H3 geospatial indexing system",
    "type": "library",
    "license": "Apache-2.0",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "H3\\": "src/"
        }
    },
    "autoload-dev": {
        "H3\\Tests\\": "tests/"
    },
    "keywords": [
        "geospatial",
        "h3",
        "indexing",
        "hexagonal-grid",
        "uber"
    ],
    "support": {
        "issues": "https://github.com/ligorikus/h3-php/issues",
        "source": "https://github.com/ligorikus/h3-php"
    }
}